NODE_ENV=development
PORT=9092
LOG_LEVEL=info

APP_BASE_URL=http://localhost:9092
WEB_BASE_URL=http://localhost:5173

# MongoDB. For local dev with transactions, run a single-node replica set
# (e.g. `mongod --replSet rs0` + `rs.initiate()`), or use MongoDB Atlas.
MONGODB_URI=mongodb://127.0.0.1:27017/lovebook

JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# External file-service proxy (photos + voice notes).
FILE_SERVICE_BASE_URL=https://go-file-service-production.up.railway.app

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
# Optional in dev; required in production for push to send.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@lovebook.app
